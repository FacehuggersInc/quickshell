{
    "wallpapers": {
        "darkModeHours": {
            "before": 5,
            "at": 21
        },
        "displays": [
            "DP-2",
            "HDMI-A-1",
            "DP-1"
        ],
        "primaryDisplayIndex": 1,
        "randomWallpaperPerDisplay": true,
        "interval": 600000,
        "day": "/home/fach/Pictures/Wallpapers/Day/",
        "night": "/home/fach/Pictures/Wallpapers/Night/",
        "smartCrop": true
    },
    "commands": {
        "terminal": "ghostty",
        "terminal_run": "ghostty -e bash -c",
        "screenshot": "flameshot gui",
        "files": "nautilus",
        "files_open": "nautilus {path}",
        "colorpicker": "hyprpicker",
        "editor": "code",
        "config_main": "code /home/fach/.config/",
        "config_hypr": "code /home/fach/.config/hypr/",
        "config_quickshell": "code /home/fach/.config/quickshell/",
        "suspend": "systemctl suspend",
        "reboot": "systemctl reboot",
        "poweroff": "systemctl poweroff",
        "logout": "bash -c command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit",
        "restart_shell": "/home/fach/.config/quickshell/Scripts/restart.sh",
        "hypr_reload": "hyprctl reload",
        "wallpaper_set": "awww img -o {display} {wallpaper}"
    },
    "iconsPath": "/home/fach/.local/share/icons/material/",
    "volumePercentageOffset": 0,
    "fontFamily": "JetBrainsMono",
    "theme": {
        "mode": "dark",
        "background": "#0f0c15",
        "surface": "#23202a",
        "primary": "#665e73",
        "secondary": "#4f4859",
        "text": "#e8d5ff"
    },
    "launcherflags": {
        "maxOptions": 3,
        "filters": {
            "org.gnome.Nautilus": [
                "--gapplication-service"
            ]
        },
        "setOptions": {},
        "lockOptions": [
            "brave-cinhimbnkkaeohfgghhklpknlkffjgod-Default",
            "brave-chcecgcbjkilfgeccdhoeaillkophnhg-Default"
        ],
        "ignoreOptions": [
            "steam",
            "brave-browser",
            "BattleNet",
            "net.lutris.Lutris",
            "discord"
        ]
    },
    "launchers": [
        {
            "name": "code",
            "nickname": "Visual Studio Code",
            "icon": "/usr/share/icons/Papirus/64x64/apps/code.svg",
            "command": "/opt/visual-studio-code/code",
            "options": [
                [
                    "/home/fach/.config/quickshell/"
                ],
                [
                    "/home/fach/.config/hypr/"
                ],
                [
                    "/home/fach/.config/mimeapps.list"
                ]
            ]
        },
        {
            "name": "com.mitchellh.ghostty",
            "nickname": "Ghostty",
            "icon": "/usr/share/icons/Papirus/64x64/apps/com.mitchellh.ghostty.svg",
            "command": "ghostty",
            "options": [
                [
                    "--gtk-single-instance=true",
                    "-e",
                    "appimagelauncherd",
                    "/home/fach/Launchers/PINCE.appimage"
                ],
                [
                    "--gtk-single-instance=true",
                    "-e",
                    "appimagelauncherd",
                    "/mnt/ssd-games/Emulators/DuskLight/Dusklight-v1.1.1-linux-x86_64.AppImage"
                ],
                [
                    "-e",
                    "bash",
                    "-c",
                    "r2modman"
                ]
            ]
        },
        {
            "name": "brave-browser",
            "nickname": "Brave",
            "icon": "/usr/share/icons/Papirus/64x64/apps/brave-browser.svg",
            "command": "/opt/brave-bin/brave",
            "options": []
        },
        {
            "name": "brave-cinhimbnkkaeohfgghhklpknlkffjgod-Default",
            "nickname": "Youtube Music",
            "icon": "/usr/share/icons/Papirus/64x64/apps/brave-cinhimbnkkaeohfgghhklpknlkffjgod-Default.svg",
            "command": "/opt/brave-bin/brave",
            "options": [
                [
                    "--profile-directory=Default",
                    "--app-id=cinhimbnkkaeohfgghhklpknlkffjgod"
                ]
            ]
        },
        {
            "name": "brave-chcecgcbjkilfgeccdhoeaillkophnhg-Default",
            "nickname": "Xbox Cloud Gaming",
            "icon": "/usr/share/icons/Papirus/64x64/apps/brave-chcecgcbjkilfgeccdhoeaillkophnhg-Default.svg",
            "command": "/opt/brave-bin/brave",
            "options": [
                [
                    "--profile-directory=Default",
                    "--app-id=chcecgcbjkilfgeccdhoeaillkophnhg"
                ]
            ]
        },
        {
            "name": "steam",
            "nickname": "Steam",
            "icon": "/usr/share/icons/Papirus/64x64/apps/steam.svg",
            "command": "steam",
            "options": []
        },
        {
            "name": "BattleNet",
            "icon": "/home/fach/.local/share/icons/hicolor/128x128/apps/lutris_battlenet.png",
            "command": "gio launch /home/fach/.local/share/applications/net.lutris.diablo-iv-2.desktop",
            "masque": {
                "classIncludes": "",
                "cmdIncludes": "Battle.net"
            }
        },
        {
            "name": "org.gnome.SystemMonitor",
            "nickname": "System Monitor",
            "icon": "/usr/share/icons/Papirus/64x64/apps/org.gnome.SystemMonitor.svg",
            "command": "gnome-system-monitor",
            "options": []
        },
        {
            "name": "org.gnome.Nautilus",
            "nickname": "Files",
            "icon": "/usr/share/icons/Papirus/64x64/apps/org.gnome.Nautilus.svg",
            "command": "nautilus",
            "options": [
                [
                    "--new-window"
                ],
                [
                    "--new-window",
                    "/home/fach/.local/share/icons/material/"
                ],
                [
                    "."
                ]
            ]
        },
        {
            "name": "input-remapper-gtk",
            "nickname": "Input Remapper",
            "icon": "/usr/share/icons/hicolor/scalable/apps/input-remapper.svg",
            "command": "/usr/bin/input-remapper-gtk",
            "options": []
        },
        {
            "name": "net.lutris.Lutris",
            "icon": "/usr/share/icons/hicolor/128x128/apps/net.lutris.Lutris.png",
            "command": "/usr/bin/lutris",
            "options": []
        },
        {
            "name": "org.prismlauncher.PrismLauncher",
            "nickname": "",
            "icon": "/usr/share/icons/Papirus/64x64/apps/org.prismlauncher.PrismLauncher.svg",
            "command": "/app/bin/prismrun",
            "options": []
        },
        {
            "name": "godot",
            "nickname": "Godot Engine",
            "icon": "/usr/share/icons/Papirus/64x64/apps/godot.svg",
            "command": "godot",
            "options": [],
            "masque": {
                "classIncludes": "Godot"
            }
        },
        {
            "name": "Aseprite",
            "nickname": "",
            "icon": "/usr/share/icons/Papirus/64x64/apps/aseprite.svg",
            "command": "/mnt/ssd-games/SteamLibrary/steamapps/common/Aseprite/aseprite",
            "options": []
        },
        {
            "name": "localsend",
            "nickname": "",
            "icon": "/usr/share/icons/Papirus/64x64/apps/org.localsend.localsend_app.svg",
            "command": "localsend",
            "options": [
                [
                    "<defunct>"
                ]
            ]
        }
    ],
    "colorHistory": [
        "#342e05",
        "#141414",
        "#799c56"
    ],
    "forceDarkMode": false,
    "wallpaperMode": 2
}